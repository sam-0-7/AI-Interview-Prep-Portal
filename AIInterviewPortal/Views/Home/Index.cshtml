@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<section class="hero">

    <div class="hero-left">

        <h1>
            Prepare <span>Smarter.</span><br />
            Get Hired <span>Faster.</span>
        </h1>

        <p>
            Master your technical interviews with AI-powered mock interviews,
            instant feedback, performance analytics, and personalized learning
            paths designed to boost your confidence.
        </p>

        <div class="hero-buttons">

            <a href="/Account/Register" class="btn-primary-custom text-decoration-none" style="display:inline-block;">
                <i class="fa-solid fa-play"></i>
                Start Interview
            </a>

            <a href="#features" class="btn-secondary-custom text-decoration-none" style="display:inline-block;">
                Learn More
            </a>

        </div>

    </div>

    <div class="hero-right">

        <div class="hero-card">

            <i class="fa-solid fa-robot robot"></i>

            <div class="tech-icon">
                <i class="fa-brands fa-html5"></i>
            </div>

            <div class="tech-icon">
                <i class="fa-brands fa-css3-alt"></i>
            </div>

            <div class="tech-icon">
                <i class="fa-brands fa-js"></i>
            </div>

            <div class="tech-icon">
                <i class="fa-brands fa-microsoft"></i>
            </div>

        </div>

    </div>

</section>

<section class="tech-section" id="technologies">

    <h2>Popular Interview Technologies</h2>

    <div class="tech-grid">

        <div class="tech-card">
            <i class="fa-brands fa-microsoft" style="color: #6EA6FF;"></i>
            <h3>.NET</h3>
            <p>ASP.NET Core MVC, Web API, Entity Framework</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-java" style="color: #FF5722;"></i>
            <h3>Java</h3>
            <p>Core Java, Spring Boot, Hibernate</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-python" style="color: #FFD600;"></i>
            <h3>Python</h3>
            <p>Django, Flask, Data Structures</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-js" style="color: #FFDF00;"></i>
            <h3>JavaScript</h3>
            <p>React, Node.js, Express</p>
        </div>

        <div class="tech-card">
            <i class="fa-solid fa-database" style="color: #4CAF50;"></i>
            <h3>SQL</h3>
            <p>Queries, Joins, Stored Procedures</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-git-alt" style="color: #F05032;"></i>
            <h3>Git</h3>
            <p>Version Control & GitHub</p>
        </div>

    </div>

</section>

<section class="features" id="features">

    <div class="container">

        <h2 class="text-center mb-5" style="color: white; font-size: 40px; font-weight: 700;">
            Why Choose Our AI Interview Portal?
        </h2>

        <div class="row g-4">

            <div class="col-lg-4">

                <div class="tech-card" style="cursor: default;">

                    <i class="fa-solid fa-microchip" style="color: #FFF176; font-size: 60px; margin-bottom: 25px;"></i>

                    <h4>AI Interviewer</h4>

                    <p style="opacity: 0.9; margin-top: 10px;">
                        Experience realistic interview sessions powered by AI.
                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="tech-card" style="cursor: default;">

                    <i class="fa-solid fa-chart-line" style="color: #4FD8FF; font-size: 60px; margin-bottom: 25px;"></i>

                    <h4>Performance Analytics</h4>

                    <p style="opacity: 0.9; margin-top: 10px;">
                        Analyze strengths and identify improvement areas.
                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="tech-card" style="cursor: default;">

                    <i class="fa-solid fa-award" style="color: #8D7BFF; font-size: 60px; margin-bottom: 25px;"></i>

                    <h4>Certification</h4>

                    <p style="opacity: 0.9; margin-top: 10px;">
                        Complete interviews and unlock achievements.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<section class="stats" style="margin-top: 80px; padding: 40px 10%;">

    <div class="container">

        <div class="row text-center g-4">

            <div class="col-md-3">

                <div class="tech-card" style="cursor: default; padding: 30px 20px;">

                    <h1 style="font-size: 48px; font-weight: 800; color: #FFF176;">15K+</h1>

                    <p style="margin: 0;">Students</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="tech-card" style="cursor: default; padding: 30px 20px;">

                    <h1 style="font-size: 48px; font-weight: 800; color: #4FD8FF;">600+</h1>

                    <p style="margin: 0;">Interview Questions</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="tech-card" style="cursor: default; padding: 30px 20px;">

                    <h1 style="font-size: 48px; font-weight: 800; color: #8D7BFF;">25+</h1>

                    <p style="margin: 0;">Technologies</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="tech-card" style="cursor: default; padding: 30px 20px;">

                    <h1 style="font-size: 48px; font-weight: 800; color: #FFF176;">96%</h1>

                    <p style="margin: 0;">Success Rate</p>

                </div>

            </div>

        </div>

    </div>

</section>

<div class="text-center" style="margin-top: 100px; padding: 80px 10%; background: rgba(255, 255, 255, .1); border-radius: 30px; border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(10px); width: 90%; margin-left: auto; margin-right: auto; max-width: 1000px;">

    <h2 style="font-size: 38px; font-weight: 700; color: white;">Ready to Crack Your Dream Job?</h2>

    <p style="margin-top: 20px; font-size: 18px; opacity: 0.9; max-width: 700px; margin-left: auto; margin-right: auto;">
        Practice smarter, improve faster, and build confidence with AI-powered interview preparation.
    </p>

    <a href="/Account/Register" class="btn-primary-custom text-decoration-none" style="display:inline-block; margin-top: 30px;">
        Start Free Interview
    </a>

</div>
