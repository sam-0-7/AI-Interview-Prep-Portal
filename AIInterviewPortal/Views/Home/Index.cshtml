@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<div id="view-landing" class="view-section active">
    <section class="hero">
        <div class="hero-left">
            <h1>Prepare <span>Smarter.</span><br>Get Hired <span>Faster.</span></h1>
            <p>Master your technical interviews with AI-powered mock interviews, instant feedback, performance analytics, and personalized learning paths designed to boost your confidence.</p>
            <div class="hero-buttons">
                <a href="/Account/Register" class="btn-primary-custom" style="text-decoration:none">
                    <i class="fa-solid fa-play"></i> Start Interview
                </a>
                <a href="#features" class="btn-secondary-custom" style="text-decoration:none">Learn More</a>
            </div>
        </div>
        <div class="hero-right">
            <div class="hero-card">
                <i class="fa-solid fa-robot robot"></i>
                <div class="tech-icon"><i class="fa-brands fa-html5" style="color:#e34f26;"></i></div>
                <div class="tech-icon"><i class="fa-brands fa-css3-alt" style="color:#1572b6;"></i></div>
                <div class="tech-icon"><i class="fa-brands fa-js" style="color:#f7df1e;"></i></div>
                <div class="tech-icon"><i class="fa-brands fa-microsoft" style="color:#0078d4;"></i></div>
            </div>
        </div>
    </section>

    <section class="tech-section" id="technologies">
        <h2>Popular Interview Technologies</h2>
        <div class="tech-grid">
            <a href="/Account/Register" class="tech-card" style="text-decoration:none">
                <i class="fa-brands fa-microsoft" style="color: #6EA6FF;"></i>
                <h3>.NET</h3>
                <p>ASP.NET Core MVC, Web API, Entity Framework</p>
            </a>
            <a href="/Account/Register" class="tech-card" style="text-decoration:none">
                <i class="fa-brands fa-java" style="color: #FF5722;"></i>
                <h3>Java</h3>
                <p>Core Java, Spring Boot, Hibernate</p>
            </a>
            <a href="/Account/Register" class="tech-card" style="text-decoration:none">
                <i class="fa-brands fa-python" style="color: #FFD600;"></i>
                <h3>Python</h3>
                <p>Django, Flask, Data Structures</p>
            </a>
            <a href="/Account/Register" class="tech-card" style="text-decoration:none">
                <i class="fa-brands fa-js" style="color: #FFDF00;"></i>
                <h3>JavaScript</h3>
                <p>React, Node.js, Express</p>
            </a>
            <a href="/Account/Register" class="tech-card" style="text-decoration:none">
                <i class="fa-solid fa-database" style="color: #4CAF50;"></i>
                <h3>SQL</h3>
                <p>Queries, Joins, Stored Procedures</p>
            </a>
            <a href="/Account/Register" class="tech-card" style="text-decoration:none">
                <i class="fa-brands fa-git-alt" style="color: #F05032;"></i>
                <h3>Git</h3>
                <p>Version Control & GitHub</p>
            </a>
        </div>
    </section>

    <section class="features" id="features">
        <h2>Why Choose Our AI Interview Portal?</h2>
        <div class="features-grid">
            <div class="tech-card" style="cursor: default;">
                <i class="fa-solid fa-microchip" style="color: var(--accent-yellow);"></i>
                <h3>AI Interviewer</h3>
                <p>Experience realistic, dynamic interview sessions generated by Google Gemini AI adapted to your skill level.</p>
            </div>
            <div class="tech-card" style="cursor: default;">
                <i class="fa-solid fa-chart-line" style="color: var(--accent-cyan);"></i>
                <h3>Performance Analytics</h3>
                <p>Detailed performance reporting mapping out your strengths and key growth areas automatically.</p>
            </div>
            <div class="tech-card" style="cursor: default;">
                <i class="fa-solid fa-award" style="color: var(--accent-purple);"></i>
                <h3>Certifications</h3>
                <p>Master specific technology paths, complete questions, and collect custom glass dashboard profile badges.</p>
            </div>
        </div>
    </section>

    <div class="cta-banner">
        <h2>Ready to Crack Your Dream Job?</h2>
        <p>Practice smarter, improve faster, and build confidence with AI-powered interview preparation.</p>
        <a href="/Account/Register" class="btn-primary-custom" style="text-decoration:none">Start Free Interview</a>
    </div>
</div>
