@inject Microsoft.AspNetCore.Identity.UserManager<AIInterviewPortal.Models.Domain.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AI-powered interview preparation portal with real-time Gemini AI feedback for technical interview practice." />
    <title>@ViewData["Title"] – AI Interview Portal</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Ambient Animated Background Blobs -->
<div class="background">
    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
    <div class="blob blob3"></div>
</div>
@if (User.Identity?.IsAuthenticated == true)
{
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? User.Identity?.Name ?? "User";
    var initials = !string.IsNullOrEmpty(fullName) ? string.Concat(fullName.Split(' ').Select(s => s[0])).ToUpper() : "U";
    if (initials.Length > 2) initials = initials.Substring(0, 2);

    <div class="dashboard-container">
        <aside class="glass-sidebar">
            <div class="sidebar-profile">
                <div class="sidebar-avatar">@initials</div>
                <h4>@fullName</h4>
                <p>@User.Identity.Name</p>
            </div>
            <ul class="sidebar-menu">
                <li>
                    <a href="/Dashboard" class="sidebar-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" style="text-decoration:none">
                        <i class="fa-solid fa-chart-pie"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/Interview/SelectTech" class="sidebar-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Interview" && ViewContext.RouteData.Values["Action"]?.ToString() == "SelectTech" ? "active" : "")" style="text-decoration:none">
                        <i class="fa-solid fa-terminal"></i> Practice Session
                    </a>
                </li>
                <li>
                    <a href="/Progress" class="sidebar-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Progress" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" style="text-decoration:none">
                        <i class="fa-solid fa-chart-line"></i> Streaks & Progress
                    </a>
                </li>
                <li>
                    <a href="/Progress/Leaderboard" class="sidebar-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Progress" && ViewContext.RouteData.Values["Action"]?.ToString() == "Leaderboard" ? "active" : "")" style="text-decoration:none">
                        <i class="fa-solid fa-trophy"></i> Leaderboard
                    </a>
                </li>
                <li>
                    <a href="/Account/Profile" class="sidebar-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")" style="text-decoration:none">
                        <i class="fa-solid fa-user"></i> My Profile
                    </a>
                </li>
                <li>
                    <form method="post" action="/Account/Logout" style="margin-top: 30px; display:block">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="sidebar-item" style="background:none; border:none; color:var(--danger); width:100%; text-align:left; padding:12px 18px; cursor:pointer">
                            <i class="fa-solid fa-sign-out-alt"></i> Sign Out
                        </button>
                    </form>
                </li>
            </ul>
        </aside>
        <main class="dashboard-main">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger" style="background: rgba(185, 28, 28, 0.2); border: 1px solid rgba(185, 28, 28, 0.4); color: white; padding: 15px; border-radius: 12px; margin-bottom: 20px;">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@TempData["Error"]</span>
                </div>
            }
            @RenderBody()
        </main>
    </div>
}
else
{
    <nav class="glass-nav">
        <a class="logo" href="/">
            <div class="logo-circle">
                <i class="fa-solid fa-brain"></i>
            </div>
            <div>
                <h4>AI Interview</h4>
                <small>Prep Portal</small>
            </div>
        </a>
        <ul class="nav-links">
            <li><a class="nav-link" href="/">Home</a></li>
            <li><a class="nav-link" href="/#features">Features</a></li>
            <li><a class="nav-link" href="/#technologies">Technologies</a></li>
        </ul>
        <div style="display:flex;align-items:center;gap:15px">
            <a href="/Account/Login" class="nav-link" id="nav-login" style="text-decoration:none">Sign in</a>
            <a href="/Account/Register" class="start-btn" style="text-decoration:none">Get Started</a>
        </div>
    </nav>

    @if (TempData["Error"] != null)
    {
        <div style="position:relative;z-index:2;padding:0 1.5rem;margin-top:15px;max-width:1200px;margin-left:auto;margin-right:auto">
            <div class="alert alert-danger" style="background: rgba(185, 28, 28, 0.2); border: 1px solid rgba(185, 28, 28, 0.4); color: white; padding: 15px; border-radius: 12px;">
                <i class="fas fa-exclamation-circle"></i>
                <span>@TempData["Error"]</span>
            </div>
        </div>
    }

    @RenderBody()

    <footer style="text-align: center; padding: 30px; background: rgba(255,255,255,0.05); margin-top: 40px; width:100%;">
        <p>© 2026 AI Interview Prep Portal. All rights reserved.</p>
    </footer>
}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
