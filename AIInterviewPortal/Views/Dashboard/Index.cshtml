@model AIInterviewPortal.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
    
    // Process completed dates for streak calendar
    var completedDates = System.Text.Json.JsonSerializer.Serialize(
        Model.RecentSessions
            .Where(s => s.IsCompleted && s.CompletedAt.HasValue)
            .Select(s => s.CompletedAt!.Value.ToString("yyyy-MM-dd"))
            .ToList()
    );

    // Process chart progression data
    var chartSessions = Model.RecentSessions.Where(s => s.IsCompleted && s.AverageScore.HasValue).Take(10).ToList();
    var chartScores = System.Text.Json.JsonSerializer.Serialize(chartSessions.Select(s => s.AverageScore!.Value).Reverse().ToList());
    var chartLabels = System.Text.Json.JsonSerializer.Serialize(chartSessions.Select(s => s.Technology?.Name ?? "").Reverse().ToList());
}

<!-- Stats Bar -->
<div class="stats-bar animate-in">
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(79, 216, 255, 0.15); color: var(--accent-cyan);">
            <i class="fa-solid fa-star"></i>
        </div>
        <div class="stat-item-info">
            <h2>@Model.AverageScore.ToString("F1")</h2>
            <p>Average Score</p>
        </div>
    </div>
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(141, 123, 255, 0.15); color: var(--accent-purple);">
            <i class="fa-solid fa-clipboard-check"></i>
        </div>
        <div class="stat-item-info">
            <h2>@Model.TotalSessions</h2>
            <p>Sessions Run</p>
        </div>
    </div>
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(255, 241, 118, 0.15); color: var(--accent-yellow);">
            <i class="fa-solid fa-fire"></i>
        </div>
        <div class="stat-item-info">
            <h2>@((Model.RecentSessions.Any(s => s.IsCompleted && s.CompletedAt.HasValue && s.CompletedAt.Value.Date == DateTime.UtcNow.Date)) ? "1" : "0") Day</h2>
            <p>Current Streak</p>
        </div>
    </div>
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(81, 207, 98, 0.15); color: var(--success);">
            <i class="fa-solid fa-ranking-star"></i>
        </div>
        <div class="stat-item-info">
            <h2>#1</h2>
            <p>Board Rank</p>
        </div>
    </div>
</div>

<div class="dashboard-row-grid mt-4">
    <!-- Chart Panel -->
    <div class="dashboard-panel-card">
        <div class="panel-header">
            <h3>Score Progression (Recent Interviews)</h3>
        </div>
        <div style="height: 250px; position: relative;">
            <canvas id="dashboardChart"></canvas>
        </div>
    </div>
    <!-- Daily Streak Panel -->
    <div class="dashboard-panel-card">
        <div class="panel-header">
            <h3>Daily Streak Calendar</h3>
            <span style="font-weight: 700; color: var(--accent-yellow);" id="streak-panel-days">Streak Calendar</span>
        </div>
        <p style="font-size: 0.8rem; opacity: 0.8; margin-bottom: 20px;">Complete an interview selection to extend your streak.</p>
        <div class="streak-grid" id="streak-calendar-grid">
            <!-- Generated Dynamically -->
        </div>
    </div>
</div>

<!-- Recent Session Logs -->
<div class="dashboard-panel-card mt-4">
    <div class="panel-header">
        <h3>Recent Interview Log</h3>
        <a href="/Interview/SelectTech" class="start-btn" style="padding: 10px 24px; font-size: 0.85rem; text-decoration:none">New Practice</a>
    </div>
    <div class="session-table-wrapper">
        <table class="session-table">
            <thead>
                <tr>
                    <th>Technology</th>
                    <th>Difficulty</th>
                    <th>Questions</th>
                    <th>Avg. Score</th>
                    <th>Completed At</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.RecentSessions.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center" style="opacity: 0.7; padding: 25px 0;">No mock sessions completed yet. Click New Practice to initiate.</td>
                    </tr>
                }
                else
                {
                    foreach (var s in Model.RecentSessions.Take(5))
                    {
                        var diffClass = s.Difficulty.ToLower() == "beginner" ? "easy" : s.Difficulty.ToLower() == "intermediate" ? "medium" : "hard";
                        <tr>
                            <td style="font-weight: 600;">@(s.Technology?.Name ?? ".NET")</td>
                            <td><span class="badge-difficulty @diffClass">@s.Difficulty</span></td>
                            <td>@s.QuestionCount</td>
                            <td style="font-weight: 700; color: @(s.AverageScore >= 8 ? "var(--success)" : s.AverageScore >= 6 ? "var(--accent-cyan)" : "var(--accent-yellow)");">
                                @(s.AverageScore.HasValue ? s.AverageScore.Value.ToString("F1") + "/10" : "In Progress")
                            </td>
                            <td style="font-size:0.8rem; opacity:0.8;">@(s.CompletedAt?.ToString("MMM dd, yyyy HH:mm") ?? "Active")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    // Generate daily streak calendar
    function renderDailyStreakGrid(containerId, streakCalendar) {
        const grid = document.getElementById(containerId);
        grid.innerHTML = "";
        
        const daysOfWeek = ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"];
        
        // Render columns headers
        daysOfWeek.forEach(day => {
            const header = document.createElement("div");
            header.style.textAlign = "center";
            header.style.fontSize = "0.78rem";
            header.style.fontWeight = "600";
            header.style.opacity = "0.6";
            header.innerText = day;
            grid.appendChild(header);
        });
        
        const now = new Date();
        const startDate = new Date();
        startDate.setDate(now.getDate() - 14 - now.getDay());
        
        for (let i = 0; i < 21; i++) {
            const checkDate = new Date(startDate);
            checkDate.setDate(startDate.getDate() + i);
            const checkStr = checkDate.toISOString().split('T')[0];
            const dayNum = checkDate.getDate();
            
            const cell = document.createElement("div");
            cell.className = "streak-day-cell";
            cell.innerText = dayNum;
            
            if (streakCalendar.includes(checkStr)) {
                cell.classList.add("active");
            }
            
            grid.appendChild(cell);
        }
    }

    const streakDates = @Html.Raw(completedDates);
    renderDailyStreakGrid("streak-calendar-grid", streakDates);

    // Render Dashboard Charts
    const ctx = document.getElementById("dashboardChart").getContext("2d");
    const scores = @Html.Raw(chartScores);
    const labels = @Html.Raw(chartLabels);
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels.length > 0 ? labels : ["None"],
            datasets: [{
                label: 'Avg. Score',
                data: scores.length > 0 ? scores : [0],
                borderColor: '#4F8CFF',
                backgroundColor: 'rgba(79, 140, 255, 0.1)',
                borderWidth: 3,
                pointBackgroundColor: '#ffffff',
                pointBorderColor: '#4F8CFF',
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 7,
                tension: 0.35,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    min: 0,
                    max: 10,
                    grid: { color: 'rgba(255, 255, 255, 0.08)' },
                    ticks: { color: 'rgba(255, 255, 255, 0.6)' }
                },
                x: {
                    grid: { display: false },
                    ticks: { color: 'rgba(255, 255, 255, 0.6)' }
                }
            }
        }
    });
</script>
}
