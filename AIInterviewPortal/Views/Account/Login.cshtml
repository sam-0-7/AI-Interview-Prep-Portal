@model AIInterviewPortal.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_Layout";
}

<section class="auth-section">
    <div class="auth-card">
        <!-- Left Panel -->
        <div class="auth-left">
            <h2>Welcome Back! 👋</h2>
            <p>Sign in to continue your technical interview preparation, track your progress, and get AI feedback.</p>
            
            <div class="register-info">
                <div class="info-item">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Real-time Gemini AI Feedback</span>
                </div>
                <div class="info-item">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>14+ Popular Technologies</span>
                </div>
                <div class="info-item">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Streaks Tracker & Leaderboard</span>
                </div>
            </div>
        </div>

        <!-- Right Panel (Form) -->
        <div class="auth-right">
            <h2>Sign In</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger" style="background: rgba(185, 28, 28, 0.2); border: 1px solid rgba(185, 28, 28, 0.4); color: white;">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>@error.ErrorMessage</span>
                    </div>
                }
            }

            <form method="post" action="/Account/Login" id="login-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="form-group">
                    <label for="login-email">Email Address</label>
                    <input type="email"
                           id="login-email"
                           name="Email"
                           class="form-control"
                           placeholder="john@gmail.com"
                           value="@Model?.Email"
                           required
                           autocomplete="email">
                </div>

                <div class="form-group mt-3">
                    <label for="login-password">Password</label>
                    <input type="password"
                           id="login-password"
                           name="Password"
                           class="form-control"
                           placeholder="••••••••"
                           required
                           autocomplete="current-password">
                </div>

                <div class="form-check mt-3" style="text-align: left; display: flex; align-items: center; gap: 8px;">
                    <input class="form-check-input"
                           type="checkbox"
                           name="RememberMe"
                           id="remember-me"
                           value="true">
                    <label class="form-check-label" for="remember-me" style="margin: 0; color: var(--text-secondary);">
                        Remember me
                    </label>
                </div>

                <button type="submit" class="btn-login mt-4">
                    Sign In
                </button>

                <hr>

                <div class="social-buttons">
                    <button type="button" class="social-btn" aria-label="Google">
                        <i class="fa-brands fa-google"></i>
                        Google
                    </button>
                    <button type="button" class="social-btn" aria-label="GitHub">
                        <i class="fa-brands fa-github"></i>
                        GitHub
                    </button>
                </div>

                <p class="text-center mt-4">
                    Don't have an account?
                    <a href="/Account/Register" style="color: white; font-weight: 600; text-decoration: none;">Create one free</a>
                </p>
            </form>
        </div>
    </div>
</section>
