@model AIInterviewPortal.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_Layout";
}

<div class="auth-wrap">
    <div class="auth-split-card">
        <!-- Left Panel -->
        <div class="auth-visual-side">
            <div style="position:relative;z-index:1">
                <!-- Brand mark -->
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:2.5rem">
                    <div class="brand-icon">
                        <i class="fas fa-brain"></i>
                    </div>
                    <span style="font-family:'DM Sans',sans-serif;font-weight:700;font-size:1rem;color:var(--text-primary)">AI Interview Portal</span>
                </div>

                <h3 style="margin-bottom:0.65rem">Welcome back</h3>
                <p>Sign in to continue your interview preparation and track your progress.</p>

                <!-- Separator -->
                <div style="width:40px;height:2px;background:rgba(var(--accent-rgb),0.4);margin:2rem 0;border-radius:1px"></div>

                <!-- Feature list -->
                <div style="display:flex;flex-direction:column;gap:0.85rem">
                    <div style="display:flex;align-items:center;gap:10px">
                        <div style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0"></div>
                        <span style="font-size:0.82rem;color:var(--text-secondary)">Real-time Gemini AI feedback</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px">
                        <div style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0"></div>
                        <span style="font-size:0.82rem;color:var(--text-secondary)">14+ technology question banks</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px">
                        <div style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0"></div>
                        <span style="font-size:0.82rem;color:var(--text-secondary)">Performance analytics & streaks</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="auth-form-side">
            <h2 style="font-family:'DM Sans',sans-serif;font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:0.3rem">Sign in</h2>
            <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.75rem">Enter your credentials to access your account</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@ViewData.ModelState.Values.SelectMany(v => v.Errors).FirstOrDefault()?.ErrorMessage</span>
                </div>
            }

            <form method="post" action="/Account/Login" id="login-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="form-group">
                    <label class="form-label" for="login-email">Email address</label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-envelope form-input-icon"></i>
                        <input id="login-email" class="form-control" type="email" name="Email"
                               placeholder="you@example.com" value="@Model?.Email" required autocomplete="email" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="login-password">Password</label>
                    <div class="form-input-wrapper">
                        <i class="fas fa-lock form-input-icon"></i>
                        <input id="login-password" class="form-control" type="password" name="Password"
                               placeholder="••••••••" required autocomplete="current-password" />
                        <button type="button" onclick="togglePassword()"
                                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.82rem;transition:color 0.2s"
                                aria-label="Toggle visibility">
                            <i class="fas fa-eye" id="eye-icon"></i>
                        </button>
                    </div>
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
                    <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.82rem;color:var(--text-secondary)">
                        <input type="checkbox" name="RememberMe" style="accent-color:var(--accent)"> Remember me
                    </label>
                    <a href="#" style="font-size:0.82rem;color:var(--accent-light);text-decoration:none;font-weight:500">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary btn-full btn-lg" id="btn-login-submit">
                    Sign in
                </button>
            </form>

            <div class="auth-divider">or continue with</div>

            <div class="auth-social-row">
                <button class="social-circle-btn" aria-label="Google"><i class="fab fa-google"></i></button>
                <button class="social-circle-btn" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></button>
                <button class="social-circle-btn" aria-label="GitHub"><i class="fab fa-github"></i></button>
            </div>

            <p style="text-align:center;font-size:0.83rem;color:var(--text-muted)">
                Don't have an account?
                <a href="/Account/Register" style="color:var(--accent-light);font-weight:500;text-decoration:none">Create one free</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePassword() {
        const field = document.getElementById('login-password');
        const icon  = document.getElementById('eye-icon');
        if (field.type === 'password') {
            field.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            field.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>
}
