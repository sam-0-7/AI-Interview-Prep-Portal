@model AIInterviewPortal.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<section class="auth-section">

    <div class="auth-card">

        <div class="auth-left">

            <h2>Create Your Account 🚀</h2>

            <p>
                Join thousands of students preparing for technical interviews
                using AI-powered mock interviews.
            </p>

            <div class="register-info">

                <div class="info-item">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Unlimited Practice</span>
                </div>

                <div class="info-item">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>AI Performance Reports</span>
                </div>

                <div class="info-item">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Track Your Progress</span>
                </div>

            </div>

        </div>

        <div class="auth-right">

            <h2>Create Account</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger" style="background: rgba(185, 28, 28, 0.2); border: 1px solid rgba(185, 28, 28, 0.4); color: white;">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>@error.ErrorMessage</span>
                    </div>
                }
            }

            <form method="post" action="/Account/Register" id="register-form">
                @Html.AntiForgeryToken()

                <div class="row">

                    <div class="col-md-12">

                        <label for="reg-name">Full Name</label>

                        <input type="text"
                               id="reg-name"
                               name="FullName"
                               class="form-control"
                               placeholder="John Doe"
                               value="@Model?.FullName"
                               required
                               autocomplete="name">

                    </div>

                </div>

                <div class="mt-3">

                    <label for="reg-email">Email Address</label>

                    <input type="email"
                           id="reg-email"
                           name="Email"
                           class="form-control"
                           placeholder="john@gmail.com"
                           value="@Model?.Email"
                           required
                           autocomplete="email">

                </div>

                <div class="row mt-3">

                    <div class="col-md-6">

                        <label for="reg-password">Password</label>

                        <input type="password"
                               id="reg-password"
                               name="Password"
                               class="form-control"
                               placeholder="********"
                               required>

                    </div>

                    <div class="col-md-6">

                        <label for="reg-confirm">Confirm Password</label>

                        <input type="password"
                               id="reg-confirm"
                               name="ConfirmPassword"
                               class="form-control"
                               placeholder="********"
                               required>

                    </div>

                </div>

                <div class="form-check mt-4">

                    <input class="form-check-input"
                           type="checkbox"
                           name="agree"
                           required>

                    <label class="form-check-label">

                        I agree to the Terms & Conditions

                    </label>

                </div>

                <button type="submit" class="btn-login mt-4">

                    Create Account

                </button>

                <hr>

                <div class="social-buttons">

                    <button type="button" class="social-btn" aria-label="Google">

                        <i class="fa-brands fa-google"></i>

                        Google

                    </button>

                    <button type="button" class="social-btn" aria-label="GitHub">

                        <i class="fa-brands fa-github"></i>

                        GitHub

                    </button>

                </div>

                <p class="text-center mt-4">

                    Already have an account?

                    <a href="/Account/Login" style="color: white; font-weight: 600; text-decoration: none;">Login</a>

                </p>

            </form>

        </div>

    </div>

</section>
