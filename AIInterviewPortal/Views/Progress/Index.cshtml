@model AIInterviewPortal.Models.ViewModels.ProgressViewModel
@{
    ViewData["Title"] = "My Progress";
    Layout = "_Layout";

    var overallPctScore = Model.OverallAvgScore > 0 ? (int)Math.Round(Model.OverallAvgScore * 10) : 0;

    var techPerformances = new Dictionary<string, int> {
        { ".NET", 92 }, { "Java", 78 }, { "Python", 68 },
        { "SQL", 60 }, { "JavaScript", 55 }
    };

    var weakAreas = new List<string> { "System Design", "Concurrency", "SQL Joins" };

    var weeklyJson = System.Text.Json.JsonSerializer.Serialize(Model.WeeklyScores);
    var weeklyLbls = System.Text.Json.JsonSerializer.Serialize(Model.WeeklyLabels);
}

<div class="panel-header" style="margin-bottom: 25px;">
    <h2>Progress & Analytics</h2>
    <p>Visualize your path to improvement across all mock interview sessions.</p>
</div>

<!-- Stats Bar -->
<div class="stats-bar animate-in">
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(141, 123, 255, 0.15); color: var(--accent-purple);">
            <i class="fa-solid fa-clipboard-check"></i>
        </div>
        <div class="stat-item-info">
            <h2>@Model.TotalSessions</h2>
            <p>Sessions</p>
        </div>
    </div>
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(79, 216, 255, 0.15); color: var(--accent-cyan);">
            <i class="fa-solid fa-star"></i>
        </div>
        <div class="stat-item-info">
            <h2>@overallPctScore%</h2>
            <p>Avg Score</p>
        </div>
    </div>
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(81, 207, 98, 0.15); color: var(--success);">
            <i class="fa-solid fa-check-double"></i>
        </div>
        <div class="stat-item-info">
            <h2>@Model.TotalQuestions</h2>
            <p>Questions</p>
        </div>
    </div>
    <div class="stat-item-card">
        <div class="stat-item-icon" style="background: rgba(255, 241, 118, 0.15); color: var(--accent-yellow);">
            <i class="fa-solid fa-hourglass-half"></i>
        </div>
        <div class="stat-item-info">
            <h2>1.5h</h2>
            <p>Total Time</p>
        </div>
    </div>
</div>

<div class="dashboard-row-grid mt-4">
    <!-- Chart Panel -->
    <div class="dashboard-panel-card">
        <div class="panel-header">
            <h3>Score Trend Over Time</h3>
        </div>
        <div style="height: 250px; position: relative;">
            <canvas id="scoreTrendChart"></canvas>
        </div>
    </div>

    <!-- Tech Skill Progression -->
    <div class="dashboard-panel-card">
        <div class="panel-header">
            <h3>Skills Snapshot</h3>
        </div>
        <div style="display:flex; flex-direction:column; gap:15px; margin-top:10px;">
            @{
                var techColors = new Dictionary<string, string> {
                    { ".NET", "#4F8CFF" }, { "Java", "#FF5722" },
                    { "Python", "#FFD600" }, { "SQL", "#4CAF50" },
                    { "JavaScript", "#FFDF00" }
                };
            }
            @foreach (var tp in techPerformances)
            {
                var tColor = techColors.GetValueOrDefault(tp.Key, "#4F8CFF");
                <div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 5px;">
                        <span style="font-weight: 500;">@tp.Key</span>
                        <span style="color: @tColor; font-weight: 600;">@tp.Value%</span>
                    </div>
                    <div class="skill-bar-bg" style="height: 6px; background: rgba(255, 255, 255, 0.08); border-radius: 4px; overflow: hidden;">
                        <div class="skill-bar-fill" style="width: @tp.Value%; height: 100%; background: @tColor; border-radius: 4px;"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="dashboard-panel-card mt-4">
    <div class="panel-header">
        <h3>Areas Needing Improvement</h3>
    </div>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top: 10px;">
        @foreach (var wa in weakAreas)
        {
            <span class="missing-point-tag" style="background: rgba(255, 107, 107, 0.1); color: var(--danger); border-color: rgba(255, 107, 107, 0.2); padding: 8px 16px; border-radius: 50px; font-weight: 600;">
                <i class="fa-solid fa-triangle-exclamation" style="margin-right: 6px"></i> @wa
            </span>
        }
    </div>
</div>

@section Scripts {
<script>
    const trendCtx = document.getElementById('scoreTrendChart');
    if (trendCtx) {
        new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: ['Session 1','Session 2','Session 3','Session 4','Session 5','Session 6','Session 7'],
                datasets: [{
                    label: 'Score %',
                    data: [65, 72, 70, 78, 75, 84, 82],
                    borderColor: '#8D7BFF',
                    backgroundColor: 'rgba(141, 123, 255, 0.1)',
                    borderWidth: 3,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#8D7BFF',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    tension: 0.35,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { 
                        min: 0, max: 100, 
                        grid: { color: 'rgba(255, 255, 255, 0.08)' },
                        ticks: { color: 'rgba(255, 255, 255, 0.6)' } 
                    },
                    x: { 
                        grid: { display: false }, 
                        ticks: { color: 'rgba(255, 255, 255, 0.6)' } 
                    }
                }
            }
        });
    }
</script>
}
