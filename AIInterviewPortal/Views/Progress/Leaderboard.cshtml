@{
    ViewData["Title"] = "Leaderboard";
    Layout = "_Layout";
    var currentUser = ViewBag.CurrentUserName;
}

<div class="panel-header" style="margin-bottom: 25px;">
    <h2>Rankings & Leaderboard</h2>
    <p>Compete with developers preparing for top tech interviews.</p>
</div>

<!-- Top 3 Podium -->
<div style="display:grid;grid-template-columns:1fr 1.1fr 1fr;gap:20px;margin-bottom:30px;align-items:end">
    <!-- Rank 2 -->
    <div class="dashboard-panel-card text-center" style="border-color:rgba(192,192,192,0.2); padding: 25px;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#94a3b8;font-weight:700;margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.08em">SILVER</div>
        <div style="width:52px;height:52px;border-radius:50%;background:#94a3b8;color:#000;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.1rem;margin:0 auto 12px;font-family:'Sora',sans-serif">NV</div>
        <div style="font-weight:700;color:var(--text-primary);font-size:0.95rem">Neha Verma</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:var(--success);font-weight:700;margin-top:4px">93%</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--text-muted);margin-top:2px">28 sessions</div>
    </div>

    <!-- Rank 1 -->
    <div class="dashboard-panel-card text-center" style="border-color:rgba(255,186,20,0.3);background:rgba(255,186,20,0.03);box-shadow:0 0 24px rgba(255,186,20,0.08); padding: 30px;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--gold);font-weight:700;margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.08em">🥇 GOLD</div>
        <div style="width:60px;height:60px;border-radius:50%;background:var(--gold);color:var(--bg-base);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.25rem;margin:0 auto 12px;font-family:'Sora',sans-serif;box-shadow:0 0 16px rgba(255,186,20,0.4)">AP</div>
        <div style="font-weight:700;color:var(--text-primary);font-size:1.05rem">Arjun Patel</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;color:var(--success);font-weight:700;margin-top:4px">96%</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--text-muted);margin-top:2px">32 sessions</div>
    </div>

    <!-- Rank 3 -->
    <div class="dashboard-panel-card text-center" style="border-color:rgba(205,127,50,0.2); padding: 25px;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#CD7F32;font-weight:700;margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.08em">BRONZE</div>
        <div style="width:52px;height:52px;border-radius:50%;background:#CD7F32;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.1rem;margin:0 auto 12px;font-family:'Sora',sans-serif">SK</div>
        <div style="font-weight:700;color:var(--text-primary);font-size:0.95rem">Sahil Khan</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:var(--success);font-weight:700;margin-top:4px">91%</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--text-muted);margin-top:2px">30 sessions</div>
    </div>
</div>

<!-- Rankings Table -->
<div class="dashboard-panel-card mt-4">
    <div class="panel-header">
        <h3>Full Rankings</h3>
    </div>
    <div class="session-table-wrapper">
        <table class="session-table">
            <thead>
                <tr>
                    <th style="width:10%;text-align:center">RANK</th>
                    <th style="width:42%">USER</th>
                    <th style="width:22%;text-align:center">SESSIONS</th>
                    <th style="width:26%;text-align:center">AVG SCORE</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="text-align:center; font-weight: 700; color: var(--gold);">1</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:28px;height:28px;border-radius:50%;background:var(--gold);color:#000;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;">AP</div>
                            <span style="font-weight:700;color:var(--text-primary)">Arjun Patel</span>
                        </div>
                    </td>
                    <td style="text-align:center;font-family:'JetBrains Mono',monospace;font-size:0.82rem">32</td>
                    <td style="text-align:center;font-weight:700;color:var(--success);font-family:'JetBrains Mono',monospace">9.6/10</td>
                </tr>
                <tr>
                    <td style="text-align:center; font-weight: 700; color: #94a3b8;">2</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:28px;height:28px;border-radius:50%;background:#94a3b8;color:#000;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;">NV</div>
                            <span style="font-weight:700;color:var(--text-primary)">Neha Verma</span>
                        </div>
                    </td>
                    <td style="text-align:center;font-family:'JetBrains Mono',monospace;font-size:0.82rem">28</td>
                    <td style="text-align:center;font-weight:700;color:var(--success);font-family:'JetBrains Mono',monospace">9.3/10</td>
                </tr>
                <tr>
                    <td style="text-align:center; font-weight: 700; color: #CD7F32;">3</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:28px;height:28px;border-radius:50%;background:#CD7F32;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;">SK</div>
                            <span style="font-weight:700;color:var(--text-primary)">Sahil Khan</span>
                        </div>
                    </td>
                    <td style="text-align:center;font-family:'JetBrains Mono',monospace;font-size:0.82rem">30</td>
                    <td style="text-align:center;font-weight:700;color:var(--success);font-family:'JetBrains Mono',monospace">9.1/10</td>
                </tr>

                <!-- Current User Highlighted -->
                <tr style="background: rgba(79, 140, 255, 0.08); border-left: 3px solid #4F8CFF;">
                    <td style="text-align:center; font-weight:700; color:#4F8CFF;">4</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:28px;height:28px;border-radius:50%;background:#4F8CFF;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;">
                                @(currentUser != null && currentUser.Length > 0 ? currentUser[0].ToString().ToUpper() : "U")
                            </div>
                            <span style="font-weight:700;color:var(--text-primary)">
                                @currentUser
                                <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#4F8CFF;margin-left:5px">(You)</span>
                            </span>
                        </div>
                    </td>
                    <td style="text-align:center;font-family:'JetBrains Mono',monospace;font-size:0.82rem;color:var(--text-primary)">24</td>
                    <td style="text-align:center;font-weight:700;color:var(--success);font-family:'JetBrains Mono',monospace">8.5/10</td>
                </tr>

                <tr>
                    <td style="text-align:center; font-weight:700; opacity:0.6;">5</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.08);color:var(--text-muted);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;">PS</div>
                            <span style="font-weight:600;color:var(--text-secondary)">Priya Singh</span>
                        </div>
                    </td>
                    <td style="text-align:center;font-family:'JetBrains Mono',monospace;font-size:0.82rem">20</td>
                    <td style="text-align:center;font-weight:700;color:var(--success);font-family:'JetBrains Mono',monospace">8.2/10</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div style="text-align:center; margin-top: 25px;">
    <p style="font-family:'JetBrains Mono',monospace;font-size:0.78rem;color:var(--text-muted)">
        Complete more sessions to climb the rankings <span style="color:var(--gold)">◈</span>
    </p>
</div>
