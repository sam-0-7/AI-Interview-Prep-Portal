@model AIInterviewPortal.Models.ViewModels.QuestionViewModel
@{
    ViewData["Title"] = $"Question {Model.CurrentNumber}";
    Layout = "_Layout";
    var progress = (double)Model.CurrentNumber / Model.TotalQuestions * 100;
}

<div class="workspace-container">
    <div class="workspace-progress-header">
        <div>
            <span id="workspace-tech-label">Technology: @Model.Technology</span>
            <span style="margin-left: 15px; opacity: 0.7;" id="workspace-difficulty-label">Difficulty: @Model.Difficulty</span>
        </div>
        <div id="workspace-progress-text">Question @Model.CurrentNumber of @Model.TotalQuestions</div>
    </div>
    <div class="progress-track-bar">
        <div class="progress-fill-bar" style="width: @progress%"></div>
    </div>

    <div class="question-workspace-card mt-3 animate-in">
        <form method="post" action="/Interview/SubmitAnswer" id="answer-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="sessionId"     value="@Model.SessionId" />
            <input type="hidden" name="questionId"    value="@Model.QuestionId" />
            <input type="hidden" name="currentNumber" value="@Model.CurrentNumber" />

            <div class="workspace-question-header">
                <div class="question-index-tag">Q@Model.CurrentNumber</div>
                <div class="timer-tag">
                    <i class="fa-regular fa-clock"></i> <span id="workspace-timer">25:00</span>
                </div>
            </div>

            <h2 class="question-prompt">@Model.QuestionText</h2>
            
            <textarea class="answer-input-area" id="workspace-answer" name="userAnswer" required
                      placeholder="Type your comprehensive answer here... Code blocks and structural descriptions are welcome."></textarea>
            
            <div class="workspace-controls-footer" id="controls-row">
                <div class="voice-mic-control">
                    <button type="button" class="mic-btn" id="mic-toggle" onclick="toggleVoiceMockSimulation()" title="Mock Voice Input">
                        <i class="fa-solid fa-microphone"></i>
                    </button>
                    <div class="speech-wave" id="mic-waves">
                        <div class="wave-bar"></div>
                        <div class="wave-bar"></div>
                        <div class="wave-bar"></div>
                        <div class="wave-bar"></div>
                        <div class="wave-bar"></div>
                    </div>
                    <span id="mic-status" style="font-size: 0.8rem; opacity: 0.75;">Click mic to simulate voice dictation</span>
                </div>
                
                <div style="display:flex; gap:10px">
                    @if (Model.CurrentNumber > 1)
                    {
                        <a href="/Interview/Question?sessionId=@Model.SessionId&questionNumber=@(Model.CurrentNumber - 1)"
                           class="btn-secondary-custom" style="padding: 12px 24px; text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="fas fa-chevron-left" style="margin-right:8px"></i> Prev
                        </a>
                    }
                    <button type="submit" class="btn-primary-custom" style="border:none" onclick="showLoading()">
                        Submit Answer <i class="fa-solid fa-check"></i>
                    </button>
                </div>
            </div>

            <!-- Loading overlay inside the card -->
            <div id="ai-loading-state" style="display:none;text-align:center;padding:2.5rem 1rem">
                <div style="display:inline-block;width:32px;height:32px;border:2px solid rgba(74, 124, 248, 0.1);border-top-color:var(--accent-cyan);border-radius:50%;animation:spin 0.8s linear infinite;margin-bottom:1.25rem"></div>
                <div class="shimmer-container">
                    <p class="shimmer-text shimmer-cycle"
                       data-phrases='["Gemini AI is analyzing your response...", "Evaluating code syntax...", "Checking technical accuracy...", "Formulating constructive feedback...", "Almost ready..."]'
                       style="font-family:'DM Sans',sans-serif;font-size:0.92rem;font-weight:600">
                        Gemini AI is analyzing your response...
                    </p>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    @@keyframes spin { to { transform: rotate(360deg); } }
    .speech-wave.active {
        display: flex !important;
    }
</style>

@section Scripts {
<script>
    let timeLeft = 25 * 60;
    const timerText = document.getElementById('workspace-timer');

    const interval = setInterval(() => {
        if (timeLeft <= 0) {
            clearInterval(interval);
            timerText.textContent = '00:00';
            timerText.style.color = 'var(--danger)';
            return;
        }
        timeLeft--;
        const mins = Math.floor(timeLeft / 60);
        const secs = timeLeft % 60;
        timerText.textContent = `${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;
        if (timeLeft < 300) timerText.style.color = 'var(--danger)';
    }, 1000);

    let isRecording = false;
    function toggleVoiceMockSimulation() {
        const waves = document.getElementById("mic-waves");
        const status = document.getElementById("mic-status");
        const toggle = document.getElementById("mic-toggle");
        
        isRecording = !isRecording;
        if (isRecording) {
            waves.classList.add("active");
            status.innerText = "Simulating voice input... speak now.";
            toggle.style.background = "var(--danger)";
            
            setTimeout(() => {
                if (isRecording) {
                    const ta = document.getElementById("workspace-answer");
                    if (ta.value) ta.value += " ";
                    ta.value += "Additionally, block-scoping ensures memory references do not leak outside the execution context.";
                    toggleVoiceMockSimulation(); // stop
                }
            }, 3000);
        } else {
            waves.classList.remove("active");
            status.innerText = "Click mic to simulate voice dictation";
            toggle.style.background = "";
        }
    }

    function showLoading() {
        const answer = document.getElementById('workspace-answer').value.trim();
        if (!answer) return;
        document.getElementById('controls-row').style.display = 'none';
        document.getElementById('ai-loading-state').style.display = 'block';
    }
</script>
}
