@model AIInterviewPortal.Models.ViewModels.FeedbackViewModel
@{
    ViewData["Title"] = "AI Feedback";
    Layout = "_Layout";
    var progress      = (double)Model.CurrentNumber / Model.TotalQuestions * 100;
    var scoreColor    = Model.Score >= 7 ? "var(--success)" : Model.Score >= 4 ? "var(--gold)" : "var(--danger)";
    var scoreColorRgb = Model.Score >= 7 ? "34,211,122" : Model.Score >= 4 ? "255,186,20" : "255,78,78";
    var nextQ         = Model.CurrentNumber + 1;
    var successMsg    = Model.Score >= 8 ? "Excellent Answer" : Model.Score >= 5 ? "Good Attempt" : "Needs Practice";
    var successIcon   = Model.Score >= 8 ? "fa-circle-check" : Model.Score >= 5 ? "fa-thumbs-up" : "fa-book-open";
}

<div class="page-container" style="max-width:920px">

    <!-- Header -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.75rem">
        <div>
            <div class="section-eyebrow"><i class="fas fa-robot"></i> AI Evaluation</div>
            <h1 class="page-title" style="font-size:1.5rem;margin-bottom:0">
                @Model.Technology · Q@Model.CurrentNumber
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--text-muted);font-weight:400;margin-left:6px">of @Model.TotalQuestions</span>
            </h1>
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--text-muted)">
            Progress: <span style="color:var(--gold);font-weight:700">@((int)progress)%</span>
        </div>
    </div>

    <!-- Main Grid -->
    <div style="display:grid;grid-template-columns:0.8fr 1.2fr;gap:1.25rem;margin-bottom:1.25rem" class="animate-in">

        <!-- Score Panel -->
        <div class="glass-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem 1.5rem;gap:0.5rem">
            <div style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--text-muted);margin-bottom:0.75rem">Score</div>

            <!-- Score Ring -->
            <div class="score-ring-wrap" style="margin:0;position:relative">
                <div style="position:absolute;inset:10px;border-radius:50%;background:radial-gradient(circle, rgba(@scoreColorRgb, 0.18) 0%, transparent 70%);filter:blur(8px)"></div>
                <div class="score-ring" style="width:130px;height:130px">
                    <svg viewBox="0 0 100 100" style="width:130px;height:130px">
                        <defs>
                            <linearGradient id="scoreGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="@scoreColor" />
                                <stop offset="100%" stop-color="@scoreColor" stop-opacity="0.6" />
                            </linearGradient>
                        </defs>
                        <circle class="track" cx="50" cy="50" r="44" />
                        <circle class="fill" cx="50" cy="50" r="44"
                                stroke-dasharray="276"
                                stroke-dashoffset="@(276 - (int)(Model.Score / 10.0 * 276))"
                                style="filter:drop-shadow(0 0 6px @scoreColor)" />
                    </svg>
                    <div class="score-label">
                        <span style="color:@scoreColor">@Model.Score.ToString("F1")</span>
                        <span class="score-sub">/ 10</span>
                    </div>
                </div>
            </div>

            <div style="margin-top:1rem;text-align:center">
                <i class="fas @successIcon" style="color:@scoreColor;font-size:1rem;margin-bottom:4px;display:block"></i>
                <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.95rem;color:@scoreColor">@successMsg</div>
            </div>
        </div>

        <!-- AI Evaluation -->
        <div class="glass-card" style="padding:1.75rem;display:flex;flex-direction:column;gap:1.25rem">

            <!-- Strengths -->
            <div>
                <div style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:var(--success);font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.65rem">
                    <i class="fas fa-arrow-trend-up" style="margin-right:4px"></i>Strengths
                </div>
                <ul style="list-style:none;display:flex;flex-direction:column;gap:7px">
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:0.86rem;color:var(--text-secondary)">
                        <i class="fas fa-check" style="color:var(--success);margin-top:4px;font-size:0.75rem"></i>
                        <span>Good structural layout of the answer response</span>
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;font-size:0.86rem;color:var(--text-secondary)">
                        <i class="fas fa-check" style="color:var(--success);margin-top:4px;font-size:0.75rem"></i>
                        <span>Core technical concepts explained accurately</span>
                    </li>
                </ul>
            </div>

            <!-- Areas to Improve -->
            <div>
                <div style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:var(--warning);font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.65rem">
                    <i class="fas fa-triangle-exclamation" style="margin-right:4px"></i>Improve
                </div>
                <ul style="list-style:none;display:flex;flex-direction:column;gap:7px">
                    @if (Model.MissingPoints.Count > 0)
                    {
                        @foreach (var pt in Model.MissingPoints)
                        {
                            <li style="display:flex;align-items:flex-start;gap:8px;font-size:0.86rem;color:var(--text-secondary)">
                                <i class="fas fa-minus" style="color:var(--warning);margin-top:4px;font-size:0.75rem"></i>
                                <span>@pt</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li style="display:flex;align-items:flex-start;gap:8px;font-size:0.86rem;color:var(--text-secondary)">
                            <i class="fas fa-minus" style="color:var(--warning);margin-top:4px;font-size:0.75rem"></i>
                            <span>Add more real-world examples and clarify runtime lifetimes</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Suggested Answer -->
    @if (!string.IsNullOrWhiteSpace(Model.SuggestedAnswer))
    {
        <div class="glass-card animate-in" style="padding:0;margin-bottom:1.25rem;overflow:hidden">
            <details>
                <summary style="padding:1.1rem 1.5rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;user-select:none">
                    <div style="display:flex;align-items:center;gap:8px">
                        <i class="fas fa-lightbulb" style="color:var(--gold);font-size:0.85rem"></i>
                        <span style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.95rem;color:var(--text-primary)">Model Answer</span>
                    </div>
                    <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--text-muted)">Click to expand ▾</span>
                </summary>
                <div style="padding:0 1.5rem 1.5rem;border-top:1px solid var(--border)">
                    <p class="suggested-text" style="margin-top:1rem;font-family:'Space Grotesk',sans-serif">@Model.SuggestedAnswer</p>
                </div>
            </details>
        </div>
    }

    <!-- Navigation -->
    <div style="display:flex;justify-content:flex-end;gap:0.75rem">
        @if (Model.IsLastQuestion)
        {
            <a href="/Interview/Summary?sessionId=@Model.SessionId" class="btn btn-primary btn-lg" id="btn-view-summary">
                <i class="fas fa-chart-bar"></i> Session Summary
            </a>
        }
        else
        {
            <a href="/Interview/Question?sessionId=@Model.SessionId&questionNumber=@nextQ"
               class="btn btn-primary btn-lg" id="btn-next-question">
                Next Question <i class="fas fa-chevron-right"></i>
            </a>
        }
    </div>
</div>

<style>
    details summary::-webkit-details-marker { display: none; }
    details summary { list-style: none; }
</style>
