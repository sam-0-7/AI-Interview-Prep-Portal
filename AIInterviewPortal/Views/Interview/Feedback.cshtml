@model AIInterviewPortal.Models.ViewModels.FeedbackViewModel
@{
    ViewData["Title"] = "AI Feedback";
    Layout = "_Layout";
    
    var dashoffset = 377 - (377 * (Model.Score / 10.0));
    var scoreColor = Model.Score >= 7.0 ? "var(--success)" : Model.Score >= 5.0 ? "var(--accent-yellow)" : "var(--danger)";
    var scoreText = Model.Score >= 8.5 ? "Excellent Response!" : Model.Score >= 7.0 ? "Very Good!" : Model.Score >= 5.0 ? "Good Try, Review Suggestions" : "Needs Practice";
    var nextQ = Model.CurrentNumber + 1;
}

<div class="feedback-container">
    <div class="panel-header">
        <h2>AI Feedback Report</h2>
        <span class="question-index-tag">@Model.Technology - Question @Model.CurrentNumber of @Model.TotalQuestions</span>
    </div>

    <div class="feedback-layout">
        <!-- Left: Circular Score Circle -->
        <div class="feedback-score-side">
            <div class="score-circular-container">
                <svg class="score-svg">
                    <circle class="score-svg-bg" cx="70" cy="70" r="60"></circle>
                    <circle class="score-svg-fill" cx="70" cy="70" r="60" 
                            style="stroke: @scoreColor; stroke-dashoffset: @dashoffset;"></circle>
                </svg>
                <div class="score-digits" style="color: @scoreColor">@Model.Score.ToString("F1")<span>/10</span></div>
            </div>
            <div class="score-text-banner" style="color: @scoreColor">@scoreText</div>
            <p style="font-size: 0.8rem; opacity: 0.75;">Reviewed by Gemini AI</p>
        </div>

        <!-- Right: Feedback Details -->
        <div class="feedback-details-side">
            <div class="ai-feedback-box">
                <h4>AI Analysis</h4>
                <p>@Model.Feedback</p>
            </div>

            <div class="ai-feedback-box">
                <h4>Critical Missing Concepts</h4>
                <div class="missing-tag-container">
                    @if (Model.MissingPoints != null && Model.MissingPoints.Any())
                    {
                        foreach (var pt in Model.MissingPoints)
                        {
                            <div class="missing-point-tag">@pt</div>
                        }
                    }
                    else
                    {
                        <div class="missing-point-tag" style="background: rgba(81, 207, 98, 0.1); color: var(--success); border-color: rgba(81, 207, 98, 0.2);">No major gaps identified</div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.SuggestedAnswer))
            {
                <div class="ai-feedback-box">
                    <h4>Suggested Model Answer</h4>
                    <div class="suggested-text">@Model.SuggestedAnswer</div>
                </div>
            }
        </div>
    </div>

    <div style="text-align: right; margin-top: 30px;">
        @if (Model.IsLastQuestion)
        {
            <a href="/Interview/Summary?sessionId=@Model.SessionId" class="btn-primary-custom" style="text-decoration: none;">
                View Summary <i class="fa-solid fa-chart-line" style="margin-left: 8px"></i>
            </a>
        }
        else
        {
            <a href="/Interview/Question?sessionId=@Model.SessionId&questionNumber=@nextQ" class="btn-primary-custom" style="text-decoration: none;">
                Next Question <i class="fa-solid fa-arrow-right" style="margin-left: 8px"></i>
            </a>
        }
    </div>
</div>
