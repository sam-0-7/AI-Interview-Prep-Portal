@model AIInterviewPortal.Models.ViewModels.SessionSummaryViewModel
@{
    ViewData["Title"] = "Session Summary";
    Layout = "_Layout";
    
    var avgVal = Model.AverageScore;
    var resultText = avgVal >= 8.5 ? "Excellent job! You are thoroughly ready for technical interviews." 
                     : avgVal >= 7.0 ? "Good performance. A few minor concepts left to review." 
                     : "Some critical knowledge gaps found. We suggest reviewing model answers.";
    var resultColor = avgVal >= 8.5 ? "var(--success)" 
                      : avgVal >= 7.0 ? "var(--accent-cyan)" 
                      : "var(--accent-yellow)";
}

<div class="feedback-container">
    <div class="panel-header text-center" style="margin-bottom: 40px; width: 100%;">
        <h2>Mock Interview Complete 🎉</h2>
        <p style="opacity: 0.9;">Technology: @Model.Technology • Difficulty: @Model.Difficulty</p>
    </div>

    <div class="summary-grid">
        <!-- Average Score Card -->
        <div class="summary-card text-center">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; color: var(--accent-cyan); letter-spacing: 1px;">Average Score</h3>
            <h1 style="font-size: 3.5rem; font-weight: 800; margin: 15px 0; color: @resultColor;">@avgVal.ToString("F1")</h1>
            <p style="font-size: 0.85rem; opacity: 0.85; color: @resultColor">@resultText</p>
        </div>

        <!-- Focus Areas Card -->
        <div class="summary-card">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; color: var(--accent-yellow); letter-spacing: 1px;">Focus Areas</h3>
            <ul class="weakness-list" style="margin-top: 15px; list-style: none; padding: 0;">
                @if (Model.WeakAreas != null && Model.WeakAreas.Any())
                {
                    foreach (var area in Model.WeakAreas)
                    {
                        <li class="weakness-item" style="display: flex; align-items: flex-start; gap: 10px; font-size: 0.9rem; margin-bottom: 10px; color: var(--text-secondary);">
                            <i class="fa-solid fa-triangle-exclamation" style="color: var(--danger); margin-top: 3px;"></i>
                            <span>@area</span>
                        </li>
                    }
                }
                else
                {
                    <li class="weakness-item" style="display: flex; align-items: flex-start; gap: 10px; font-size: 0.9rem; margin-bottom: 10px; color: var(--success);">
                        <i class="fa-solid fa-circle-check" style="margin-top: 3px;"></i>
                        <span>No major weakness areas identified! Great coverage of topics.</span>
                    </li>
                }
            </ul>
        </div>
    </div>

    <!-- Question Breakdown Panel -->
    <div class="dashboard-panel-card mt-4">
        <h3>Question Breakdown</h3>
        <div class="session-table-wrapper mt-3">
            <table class="session-table">
                <thead>
                    <tr>
                        <th>Question</th>
                        <th>Your Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model.QnA)
                    {
                        var qScoreColor = q.Score >= 8.0 ? "var(--success)" : q.Score >= 6.0 ? "var(--accent-cyan)" : "var(--accent-yellow)";
                        <tr>
                            <td style="font-weight: 500;">@q.Question</td>
                            <td style="font-weight: 700; color: @qScoreColor;">@q.Score.ToString("F1")/10</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div style="text-align: center; margin-top: 40px; display: flex; justify-content: center; gap: 15px;">
        <a href="/Dashboard" class="btn-primary-custom" style="text-decoration: none;">
            Go to Dashboard
        </a>
        <a href="/Interview/SelectTech" class="btn-secondary-custom" style="text-decoration: none;">
            Practice More
        </a>
    </div>
</div>
