@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="hero">

    <div class="hero-left">

        <h1>
            Prepare <span>Smarter.</span><br />
            Get Hired <span>Faster.</span>
        </h1>

        <p>
            Master your technical interviews with AI-powered mock interviews,
            instant feedback, performance analytics, and personalized learning
            paths designed to boost your confidence.
        </p>

        <div class="hero-buttons">

            <button class="btn-primary-custom">
                <i class="fa-solid fa-play"></i>
                Start Interview
            </button>

            <button class="btn-secondary-custom">
                Learn More
            </button>

        </div>

    </div>

    <div class="hero-right">

        <div class="hero-card">

            <i class="fa-solid fa-robot robot"></i>

            <div class="tech-icon">
                <i class="fa-brands fa-html5"></i>
            </div>

            <div class="tech-icon">
                <i class="fa-brands fa-css3-alt"></i>
            </div>

            <div class="tech-icon">
                <i class="fa-brands fa-js"></i>
            </div>

            <div class="tech-icon">
                <i class="fa-brands fa-microsoft"></i>
            </div>

        </div>

    </div>

</section>

<section class="tech-section">

    <h2>Popular Interview Technologies</h2>

    <div class="tech-grid">

        <div class="tech-card">
            <i class="fa-brands fa-microsoft"></i>
            <h3>.NET</h3>
            <p>ASP.NET Core MVC, Web API, Entity Framework</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-java"></i>
            <h3>Java</h3>
            <p>Core Java, Spring Boot, Hibernate</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-python"></i>
            <h3>Python</h3>
            <p>Django, Flask, Data Structures</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-js"></i>
            <h3>JavaScript</h3>
            <p>React, Node.js, Express</p>
        </div>

        <div class="tech-card">
            <i class="fa-solid fa-database"></i>
            <h3>SQL</h3>
            <p>Queries, Joins, Stored Procedures</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-git-alt"></i>
            <h3>Git</h3>
            <p>Version Control & GitHub</p>
        </div>

    </div>

</section>

<section class="features">

    <div class="container">

        <h2 class="text-center mb-5">
            Why Choose Our AI Interview Portal?
        </h2>

        <div class="row g-4">

            <div class="col-lg-4">

                <div class="feature-card">

                    <i class="fa-solid fa-microchip"></i>

                    <h4>AI Interviewer</h4>

                    <p>
                        Experience realistic interview sessions powered by AI.
                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="feature-card">

                    <i class="fa-solid fa-chart-line"></i>

                    <h4>Performance Analytics</h4>

                    <p>
                        Analyze strengths and identify improvement areas.
                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="feature-card">

                    <i class="fa-solid fa-award"></i>

                    <h4>Certification</h4>

                    <p>
                        Complete interviews and unlock achievements.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<section class="stats">

    <div class="container">

        <div class="row text-center">

            <div class="col-md-3">

                <div class="stat-card">

                    <h1>15K+</h1>

                    <p>Students</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <h1>600+</h1>

                    <p>Interview Questions</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <h1>25+</h1>

                    <p>Technologies</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <h1>96%</h1>

                    <p>Success Rate</p>

                </div>

            </div>

        </div>

    </div>

</section>

<section class="cta">

    <div class="cta-card">

        <h2>Ready to Crack Your Dream Job?</h2>

        <p>
            Practice smarter, improve faster, and build confidence with AI-powered interview preparation.
        </p>

        <button class="btn-primary-custom">
            Start Free Interview
        </button>

    </div>

</section>